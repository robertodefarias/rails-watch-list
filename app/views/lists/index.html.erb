<div class="netflix-home">
  <div class="home-hero">
    <div class="home-hero-overlay">
      <div class="container">
        <h1 class="home-title">My Lists</h1>
        <p class="home-subtitle">Create and organize your movie collections</p>

        <%= link_to "Create a new list", new_list_path, class: "netflix-main-btn" %>
      </div>
    </div>
  </div>

  <div class="container py-5">
    <div class="cards">

      <% @lists.each do |list| %>

        <%= link_to list_path(list),
  class: "card-category",
  style: "background-image:
  linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)),
  url(<%= list.photo.attached? ? cl_image_path(list.photo.key) : 'https://picsum.photos/600/400?random=' + list.id.to_s %>)" do %>

          <span><%= list.name %></span>

        <% end %>

      <% end %>

    </div>
  </div>
</div>
