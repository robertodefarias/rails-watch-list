<h1>My Lists</h1>

<div class="cards">

  <% @lists.each do |list| %>

    <%= link_to list_path(list),
        class: "card-category",
        style: "background-image:
        linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)),
        url(https://picsum.photos/400/300?random=#{list.id})" do %>

      <%= list.name %>

    <% end %>

  <% end %>

</div>

<br>

<%= link_to "Create a new list", new_list_path, class: "btn btn-primary" %>
